server
	listen 8080
	root ./www/
	server_name site.com

	methods GET POST
	locations /
		return 301 /Home

	locations /Home
		alias ./www/html/Home.html
	locations /Dart
		alias ./www/html/Dart.html
	locations /Account
		methods GET
		alias ./www/html/Account.html
	locations /signup
		methods GET
		alias ./www/html/Connected.html
	locations /signin
		methods GET
		alias ./www/html/Connected.html
	locations /logout
		methods GET
		alias ./www/html/Account.html
	
	locations /img/
		alias ./www/static/
	locations /css/
	locations /js/
	locations /cgi/
		cgi_enabled true
		methods GET
		cgi_ext .py /usr/bin/python3

		

server
	server_name localhost
	listen 8080
	cgi_ext .exrt ./YoupiBanane/cgi_tester 
	root ./
	
	locations /
		methods GET
		auto_index True

	locations /post_body
		methods POST
		client_max_body_size 100
	
	locations /directory/
		methods GET POST
		alias ./YoupiBanane/
		index youpi.bad_extension
